# Admin portal — all config lives here (or in `--env` at deploy), never in the UI.
# The admin backend's FQDN (APP_ROLE=admin deployment). Required.
BACKEND_URL=https://support-desk-admin-<org>.ignite.dodil.cloud/
# Admin key injected server-side into every proxied call; the browser never sees
# it. Required — the admin backend is fail-closed without ADMIN_KEYS anyway.
ADMIN_KEY=ak_choose_a_secret
# PORT=8789
