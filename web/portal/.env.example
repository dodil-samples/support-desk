# Customer portal — all config lives here (or in `--env` at deploy), never in the UI.
# The public backend's FQDN (APP_ROLE=public deployment). Required.
BACKEND_URL=https://support-desk-public-<org>.ignite.dodil.cloud/
# Project key injected server-side into every proxied call. Optional (omit if the
# public tier is open).
PUBLIC_KEY=pk_help_widget
# PORT=8788

# --- Sign-in (optional; mirror the backend's AUTH_MODE) ----------------------
# email mode needs nothing here — the portal proxies request_code/verify_code and
# keeps the minted session in an HttpOnly cookie automatically.
# oidc mode: this server runs the authorization-code flow against any OIDC issuer.
# OIDC_ISSUER=https://id.example.com/realms/myrealm
# OIDC_CLIENT_ID=support-portal
# OIDC_CLIENT_SECRET=...   # omit for public clients
